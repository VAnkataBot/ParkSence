<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Full-screen camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Frozen capture frame (Persona-style screenshot) -->
    <ImageView
        android:id="@+id/capturedFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Camera flash effect -->
    <View
        android:id="@+id/flashOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/white"
        android:alpha="0"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Animated scan overlay -->
    <com.parksense.ui.ScanOverlayView
        android:id="@+id/overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Branding: ParkSense top-left on scan screen -->
    <TextView
        android:id="@+id/brandingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:layout_marginStart="16dp"
        android:text="ParkSense"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#EEFFFFFF"
        android:letterSpacing="0.03"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Profile button (top-right, scan screen) -->
    <TextView
        android:id="@+id/btnProfileScan"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="4dp"
        android:gravity="center"
        android:text="👤"
        android:textSize="20sp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Settings gear (top-right) on scan screen -->
    <TextView
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="4dp"
        android:gravity="center"
        android:text="⚙"
        android:textSize="22sp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnProfileScan" />

    <!-- ════════════════════════════════════════════════════════════ -->
    <!-- Result screen                                               -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/resultCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/bg"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Top bar: back button + app name ── -->
            <RelativeLayout
                android:id="@+id/resultTopBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:paddingTop="48dp"
                android:paddingBottom="8dp"
                android:paddingHorizontal="8dp"
                android:background="@color/bg">

                <!-- Status bar spacer via fitsSystemWindows handled by theme -->
                <TextView
                    android:id="@+id/btnScanAgainTop"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:gravity="center"
                    android:text="←"
                    android:textSize="22sp"
                    android:textColor="#AAFFFFFF"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="ParkSense"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#EEFFFFFF"
                    android:letterSpacing="0.03" />

                <TextView
                    android:id="@+id/btnProfile"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center"
                    android:text="👤"
                    android:textSize="20sp"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </RelativeLayout>

            <!-- Thin separator line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0DFFFFFF" />

            <!-- ── Content area ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="28dp">

                <!-- ── Verdict card ── -->
                <LinearLayout
                    android:id="@+id/verdictCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="28dp"
                    android:paddingHorizontal="24dp"
                    android:background="@drawable/bg_verdict_unknown">

                    <!-- Verdict icon -->
                    <TextView
                        android:id="@+id/resultIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="56sp" />

                    <!-- Title -->
                    <TextView
                        android:id="@+id/resultTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@android:color/white"
                        android:gravity="center" />

                    <!-- Message -->
                    <TextView
                        android:id="@+id/resultMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="#AAFFFFFF"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>

                <!-- ── Notes section ── -->
                <TextView
                    android:id="@+id/notesHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="10dp"
                    android:text="CONDITIONS"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#66FFFFFF"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/notesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- ── Signs section ── -->
                <TextView
                    android:id="@+id/signsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="10dp"
                    android:text="SIGNS ON POLE"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#66FFFFFF"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/signsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- ── Scan again button ── -->
                <TextView
                    android:id="@+id/btnScanAgain"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:gravity="center"
                    android:text="Scan Again"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/accent"
                    android:letterSpacing="0.03"
                    android:background="@drawable/bg_scan_button"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
