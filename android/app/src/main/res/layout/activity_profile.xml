<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D12"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/btnClose"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:text="←"
                android:textSize="22sp"
                android:textColor="#AAFFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="My Profile"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#EEFFFFFF" />
        </RelativeLayout>

        <!-- Account info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_notes_card"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCOUNT"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#66FFFFFF"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#EEFFFFFF" />
        </LinearLayout>

        <!-- Vehicle profile card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_notes_card"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VEHICLE"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#66FFFFFF"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp" />

            <!-- Vehicle type -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vehicle type"
                android:textSize="12sp"
                android:textColor="#88FFFFFF"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/vehicleTypeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btnVehicleCar"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="🚗 Car"
                    android:textSize="13sp"
                    android:textColor="#EEFFFFFF"
                    android:background="@drawable/bg_vehicle_unselected"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btnVehicleMoto"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="🏍 Moto"
                    android:textSize="13sp"
                    android:textColor="#88FFFFFF"
                    android:background="@drawable/bg_vehicle_unselected"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btnVehicleEV"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="⚡ EV"
                    android:textSize="13sp"
                    android:textColor="#88FFFFFF"
                    android:background="@drawable/bg_vehicle_unselected"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btnVehicleTruck"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="🚚 Truck"
                    android:textSize="12sp"
                    android:textColor="#88FFFFFF"
                    android:background="@drawable/bg_vehicle_unselected" />

            </LinearLayout>

            <!-- Disability permit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="♿ Disability permit"
                        android:textSize="14sp"
                        android:textColor="#EEFFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allows parking in reserved ♿ spaces"
                        android:textSize="12sp"
                        android:textColor="#55FFFFFF" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDisabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Resident permit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏠 Resident permit"
                        android:textSize="14sp"
                        android:textColor="#EEFFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="For Boende/resident-only zones"
                        android:textSize="12sp"
                        android:textColor="#55FFFFFF" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchResident"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Resident zone -->
            <LinearLayout
                android:id="@+id/residentZoneRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Resident zone (optional)"
                    android:textSize="12sp"
                    android:textColor="#88FFFFFF"
                    android:layout_marginBottom="6dp"
                    android:layout_marginTop="4dp" />

                <EditText
                    android:id="@+id/etResidentZone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g. A, B4, Östermalm"
                    android:textColor="#EEFFFFFF"
                    android:textSize="14sp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Save button -->
        <TextView
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center"
            android:text="Save Changes"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#4CAF50"
            android:background="@drawable/bg_scan_button"
            android:layout_marginBottom="16dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="#4CAF50" />

        <!-- Logout -->
        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Sign Out"
            android:textSize="14sp"
            android:textColor="#66F44336"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
