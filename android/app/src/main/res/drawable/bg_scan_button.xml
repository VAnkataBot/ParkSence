<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#33ff4b4b" />
            <stroke android:width="1.5dp" android:color="#ff4b4b" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1Aff4b4b" />
            <stroke android:width="1.5dp" android:color="#44ff4b4b" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</selector>
